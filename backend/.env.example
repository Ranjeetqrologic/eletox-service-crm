# Email (SMTP)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
FROM_EMAIL=noreply@eletox.com

# Twilio (SMS/WhatsApp)
TWILIO_SID=
TWILIO_TOKEN=
TWILIO_FROM=

# Google Maps
GOOGLE_MAPS_API_KEY=

# WhatsApp Business API (future)
WHATSAPP_API_URL=
WHATSAPP_API_TOKEN=
